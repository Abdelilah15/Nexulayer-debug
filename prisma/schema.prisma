generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
}

// La table de notre Indexeur qui stockera l'historique exact
model PortfolioSnapshot {
  id        String   @id @default(uuid())
  address   String   // L'adresse du Wallet
  timestamp DateTime // La date et l'heure du snapshot
  balance   Float    // Le solde total exact en USD
  
  @@unique([address, timestamp])
  @@index([address, timestamp])
}